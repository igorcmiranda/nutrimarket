{
  "hosting": {
    "rewrites": [
      {
        "source": "/challenge",
        "function": "joinChallenge",
	"region": "southamerica-east1"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
